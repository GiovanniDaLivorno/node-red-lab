    {
        "id": "9ebccd79ff82c522",
        "type": "function",
        "z": "93e0bd9ca67d5e22",
        "name": "Validate Schema",
        "func": "let data = msg.payload;\n\nif (typeof data.name !== 'string') return null;\nif (typeof data.age !== 'number') return null;\nif (data.age < 0) return null;\n\nreturn msg;",
