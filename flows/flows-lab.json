    {
        "id": "b0eb640972286faf",
        "type": "function",
        "z": "93e0bd9ca67d5e22",
        "name": "extract JSON",
        "func": "try {\n    let text = msg.payload.response;\n    msg.payload = JSON.parse(text);\n    return msg;\n} catch (e) {\n    msg.error = \"Invalid JSON from LLM\";\n    return [null, msg];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 670,
        "y": 360,
